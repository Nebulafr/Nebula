{
  "name": "@nebula/chat-server",
  "version": "1.0.0",
  "description": "Socket.IO server for Nebula messaging",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm run db:generate",
    "build": "npx esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js --external:dotenv --external:express --external:jsonwebtoken --external:socket.io --external:zod --external:pg --external:@prisma/client",
    "build:watch": "npx esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js --external:dotenv --external:express --external:jsonwebtoken --external:socket.io --external:zod --external:pg --external:@prisma/client --watch",
    "db:generate": "npm --workspace @nebula/database run db:generate",
    "type-check": "tsc --noEmit",
    "lint": "echo 'No linting for chat-server package'",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@nebula/database": "*",
    "@nebula/integrations": "*",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "esbuild": "^0.27.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "socket.io",
    "websocket",
    "messaging",
    "real-time"
  ],
  "author": "Nebula Team",
  "license": "MIT"
}
