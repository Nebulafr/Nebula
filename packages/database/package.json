{
  "name": "@nebula/database",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "import": "./dist/src/types.js",
      "default": "./dist/src/types.js"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:categories": "tsx scripts/seed-categories.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/src/generated && cp -r src/generated/prisma dist/src/generated/",
    "lint": "echo 'No linting for database package'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.6.1",
    "pg": "^8.13.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nebula/tsconfig": "*",
    "prisma": "^7.0.0"
  }
}