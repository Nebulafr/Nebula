{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "PORT"
  ],
  "globalDependencies": [
    ".env",
    ".env.*"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "db:generate"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ],
      "env": [
        "ACCESS_TOKEN_SECRET",
        "PINECONE_API_KEY",
        "PINECONE_INDEX_NAME",
        "STRIPE_SECRET_KEY",
        "STRIPE_PUBLISHABLE_KEY",
        "OPENAI_API_KEY",
        "NEXT_PUBLIC_*"
      ]
    },
    "lint": {
      "cache": true
    },
    "type-check": {
      "cache": true
    },
    "db:generate": {
      "cache": true,
      "inputs": [
        "prisma/schema.prisma"
      ]
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "seed:admin": {
      "cache": false
    },
    "seed:categories": {
      "cache": false
    },
    "dev": {
      "dependsOn": [
        "db:generate"
      ],
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "start:prod": {
      "cache": false,
      "persistent": true
    }
  }
}