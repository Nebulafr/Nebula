{
  "name": "@nebula/chat-server",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/src/server.js",
  "types": "./dist/src/server.d.ts",
  "scripts": {
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "type-check": "tsc --noEmit",
    "lint": "echo 'No linting for chat-server package'",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@nebula/database": "*",
    "@nebula/integrations": "*",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@nebula/tsconfig": "*",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "socket.io",
    "websocket",
    "messaging",
    "real-time"
  ],
  "author": "Nebula Team",
  "license": "MIT"
}